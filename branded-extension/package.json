{
  "name": "peer-branded-extension",
  "version": "0.1.1",
  "private": true,
  "description": "Forkable, brand-neutral browser extension for privacy-preserving payment verification on the Peer protocol.",
  "license": "MIT",
  "scripts": {
    "rebrand": "node scripts/rebrand.mjs",
    "build": "vite build",
    "dev": "vite build --mode development --watch",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "vite build && node scripts/zip-release.mjs"
  },
  "dependencies": {
    "@zkp2p/sdk": "0.8.0",
    "async-mutex": "^0.4.0",
    "jsonpath-plus": "^10.4.0",
    "viem": "^2.54.6"
  },
  "overrides": {
    "ethers": {
      "ws": "8.21.0"
    }
  },
  "devDependencies": {
    "@types/chrome": "^0.0.202",
    "@types/node": "^20.4.10",
    "@vitest/coverage-v8": "^3.2.4",
    "assert": "^2.1.0",
    "crypto-browserify": "^3.12.0",
    "https-browserify": "^1.0.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "typescript": "^5.5.4",
    "url": "^0.11.3",
    "vite": "^7.0.3",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^3.2.4",
    "vm-browserify": "^1.1.2"
  }
}
